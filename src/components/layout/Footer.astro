---

<footer class="mt-8 lg:mt-4 pb-4 lg:pb-2">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="pt-4 lg:pt-2">
      <nav
        aria-label="Footer navigation"
        class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-muted-foreground"
      >
        <a href="/" class="transition-colors hover:text-foreground">Home</a>
        <a href="/about/" class="transition-colors hover:text-foreground">How It Works</a>
        <a href="/blog/" class="transition-colors hover:text-foreground">Blog</a>
        <a href="/legal/" class="transition-colors hover:text-foreground">Privacy</a>
        <a href="#" id="footer-log-run" class="transition-colors hover:text-foreground">Log a Run</a>
      </nav>
      <p class="mt-4 text-center text-xs text-muted-foreground/60">&copy; {new Date().getFullYear()} Should I Run</p>
    </div>
  </div>
</footer>

<script>
  document.getElementById("footer-log-run")?.addEventListener("click", (e) => {
    e.preventDefault();
    if (window.location.pathname !== "/") {
      window.location.href = "/";
      return;
    }
    window.dispatchEvent(new CustomEvent("runcast:open-feedback"));
    document.getElementById("feedback-section")?.scrollIntoView({ behavior: "smooth", block: "center" });
  });
</script>
