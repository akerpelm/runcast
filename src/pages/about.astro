---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
---

<Layout
  title="About RunCast — How It Works"
  description="RunCast is a free daily running briefing that tells you how to run today — not just what to wear. Weather-adjusted pace, surface warnings, and optimal timing."
>
  <Header />

  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <article>
      <div class="rounded-[var(--radius-container)] bg-background p-6 sm:p-8 neu-extruded">
        <h1 class="text-2xl font-800 tracking-tight text-foreground sm:text-3xl">
          About Run<span class="text-primary">Cast</span>
        </h1>

        <div class="mt-6 space-y-4 text-sm leading-relaxed text-muted-foreground">
          <p>
            <strong class="text-foreground">DressMyRun tells you what to wear. RunCast tells you how to run today.</strong>
          </p>
          <p>
            RunCast is a free daily running briefing for runners who want more than a wardrobe assistant.
            We take the same weather data everyone else has and layer actionable running intelligence on top:
            pace adjustments, surface warnings, optimal timing, and run type suggestions.
          </p>
        </div>

        <h2 class="mt-8 text-lg font-700 text-foreground">What We Do</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[var(--radius-base)] bg-background p-4 neu-inset-sm">
            <p class="text-sm font-semibold text-foreground">Pace Adjustment</p>
            <p class="mt-1 text-xs text-muted-foreground">Based on the Hadley temp+dew point method for heat, and wind chill for cold. Backed by exercise science.</p>
          </div>
          <div class="rounded-[var(--radius-base)] bg-background p-4 neu-inset-sm">
            <p class="text-sm font-semibold text-foreground">Surface Warnings</p>
            <p class="mt-1 text-xs text-muted-foreground">We check precipitation history, freezing conditions, and fog to warn about ice risk on sidewalks and bridges.</p>
          </div>
          <div class="rounded-[var(--radius-base)] bg-background p-4 neu-inset-sm">
            <p class="text-sm font-semibold text-foreground">Best Window</p>
            <p class="mt-1 text-xs text-muted-foreground">We scan every hour and score it for running suitability — temperature, wind, UV, precipitation, and daylight.</p>
          </div>
          <div class="rounded-[var(--radius-base)] bg-background p-4 neu-inset-sm">
            <p class="text-sm font-semibold text-foreground">Run Type Suggestion</p>
            <p class="mt-1 text-xs text-muted-foreground">Conditions dictate the workout. We'll tell you when it's a treadmill day, an easy day, or go-time.</p>
          </div>
        </div>

        <h2 class="mt-8 text-lg font-700 text-foreground">Weather Data</h2>
        <div class="mt-3 text-sm leading-relaxed text-muted-foreground">
          <p>
            Weather data comes from <a href="https://open-meteo.com" class="text-primary underline decoration-primary/30 underline-offset-2 hover:decoration-primary" target="_blank" rel="noopener noreferrer">Open-Meteo</a>,
            a free and open-source weather API. Air quality data uses the US EPA AQI scale. All data is fetched
            client-side — we don't store your location or any personal data.
          </p>
        </div>

        <h2 class="mt-8 text-lg font-700 text-foreground">Free Forever</h2>
        <div class="mt-3 text-sm leading-relaxed text-muted-foreground">
          <p>
            No subscription. No paywall. No display ads. RunCast is free because running advice should be free.
          </p>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
