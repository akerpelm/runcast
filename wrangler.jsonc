{
	"compatibility_date": "2026-04-05",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "runcast",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"html_handling": "auto-trailing-slash"
	},
	"observability": {
		"enabled": true
	}
}